{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "devCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "functions": {
    "app/main.py": {
      "excludeFiles": "{terraform/**,.omc/**,.devenv/**,.direnv/**,Dockerfile,devenv.*,*.tfstate,*.tfstate.*,*.tfvars}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "app/main.py"
    }
  ]
}
