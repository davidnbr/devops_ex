{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "devCommand": "uvicorn app.main:app --host 0.0.0.0 --port 8000",
  "functions": {
    "app/main.py": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "app/main.py"
    }
  ]
}
